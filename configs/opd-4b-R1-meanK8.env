# Phase 2.5 R1: mean-K=8 cumulative OPD (slime v2 default aggregation)
# Student: 4B Full FT v2 ckpt-700 (60% AIME, best 4B SFT baseline)
# Teacher: Qwen3-8B EXTERNAL on qzf-dev (172.31.31.105:30000, DP=4)
# Aggregation: mean (divide by actual_k), K=8 (5/29 sweet spot), gamma=1.0
# Reuses opd-4b-B paper recipe (lr=2e-6, T=0.8, max_resp=4096); 300 rollouts
# FAST knobs: no recompute + larger token budgets (no training-math impact, throughput only)
MODEL_CONFIG=qwen3-4B
STUDENT_HF=/root/.cache/huggingface/sft-qwen3-4b-full-v2-ckpt700
STUDENT_TORCH_DIST=/root/.cache/huggingface/sft-qwen3-4b-full-v2-ckpt700-torch_dist
TEACHER_HF=/root/.cache/huggingface/Qwen3-8B
TRAIN_DATA=/workspace/data/dapo-math-17k/dapo-math-17k.jsonl
SAVE_DIR=/root/.cache/huggingface/opd-4b-R1-meanK8

# External teacher (qzf-dev) — 8 GPU all for student (4 actor TP=4 + 4 rollout)
EXTERNAL_TEACHER_URL="http://172.31.31.105:30000/generate"
EXTERNAL_TEACHER_HEALTH="http://172.31.31.105:30000/health_generate"
ACTOR_GPUS=4
ACTOR_TP=4
ROLLOUT_GPUS=4

# opd-4b-B paper recipe
LR=2e-6
NUM_ROLLOUT=300
ROLLOUT_BATCH_SIZE=64
GLOBAL_BATCH_SIZE=256
N_SAMPLES=4
MAX_RESPONSE_LEN=4096
OPD_KL_COEF=1.0
SAVE_INTERVAL=50
TEMPERATURE=0.8
TOP_P=1.0
TOP_K=-1

# FAST throughput knobs (orthogonal to training math)
# NOTE: 32768 + no-recompute OOM'd on 4B actor (GPU0 only 1.65GB free). 16384 is the safe fast value.
MAX_TOKENS_PER_GPU=16384
LOG_PROBS_MAX_TOKENS_PER_GPU=24576
RECOMPUTE=0

# Cumulative OPD: mean-K=8 (gamma=1.0, truncated horizon -> divide by actual_k)
OPD_CUMULATIVE=1
OPD_GAMMA=1.0
OPD_HORIZON=8

# KL dump (every 10 rollouts) for offline analysis
OPD_DUMP_KL_PATH=/root/.cache/huggingface/opd-4b-R1-meanK8/kl_dump/r{rollout_id}_rank{rank}.jsonl
OPD_DUMP_KL_INTERVAL=10
OPD_DUMP_KL_MAX_SAMPLES=8
