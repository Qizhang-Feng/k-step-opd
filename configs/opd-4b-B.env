# ============================================================================
# opd-4b-B — Lightning-OPD paper hyperparameters (5/26 run)
# ============================================================================
# Matches Table 6 in arxiv:2604.13010 exactly:
#   lr=2e-6, max_response=4096, T=0.8, top_p=1.0, top_k=disabled,
#   global_batch=256, n_samples_per_prompt=4
#
# Note: the paper's "Lightning OPD" is offline (precomputed teacher logprobs).
# WE DID NOT IMPLEMENT THAT — this is standard online OPD with paper hyperparams.
#
# Best result: AIME-2024 = 55.8% (n=16) at iter_299, +7.0pt vs SFT baseline.
# See NAMING.md for the full mapping. opd-4b-A has conservative recipe.
# ============================================================================

# 4B OPD aligned with Lightning-OPD paper Table 6 recipe.
#
# Student: 4B Full FT v2 ckpt-700  (Qwen3-4B-Base, AIME-2024 60%)
# Teacher: Qwen3-8B post-trained
#
# Lightning-OPD paper 4B settings (Table 6 / Section 4.1):
#   training_steps=150, global_batch=256, max_response=4096, lr=2e-6 constant
#   temperature=0.8, top_p=1.0, advantage_clip [-10,10]
#   advantage_estimator=on_policy_distillation (advantage = log_T - log_S, no GRPO baseline)
#
# We can't change advantage_estimator (slime mainline doesn't have it),
# but our `--use-opd --opd-kl-coef 1.0 --advantage-estimator grpo` with reward=0
# is mathematically equivalent (group baseline=0 → advantage = -reverse_kl = log_T - log_S).
#
# Differences from instant-extteacher.env (the "wrong" run):
#   LR: 5e-7 → 2e-6 (4×)
#   MAX_RESPONSE_LEN: 8192 → 4096 (halve, paper says >4K doesn't help and slows training)
#   TEMPERATURE: 0.6 → 0.8
#   TOP_P: 0.95 → 1.0   (i.e. effectively no top-p)
#   TOP_K: 20 → -1 (no top-k)
#   NUM_ROLLOUT: 300 → 600 (Lightning trains 150 steps × bs=256 = 38400 samples;
#                            we have 600 × bs=16 × n=4 = 38400 samples too)
#   GLOBAL_BATCH_SIZE: 64 → 256  (paper Table 6)
#   ROLLOUT_BATCH_SIZE: 16 → 64  (256 / n_samples_per_prompt=4)

MODEL_CONFIG=qwen3-4B
STUDENT_HF=/root/.cache/huggingface/sft-qwen3-4b-full-v2-ckpt700
STUDENT_TORCH_DIST=/root/.cache/huggingface/sft-qwen3-4b-full-v2-ckpt700-torch_dist
TEACHER_HF=/root/.cache/huggingface/Qwen3-8B
TRAIN_DATA=/workspace/data/dapo-math-17k/dapo-math-17k.jsonl
SAVE_DIR=/root/.cache/huggingface/opd-4b-lightning-recipe

# External teacher on qzf-dev (4×L40S, DP=4, port 30000)
EXTERNAL_TEACHER_URL="http://172.31.31.105:30000/generate"
EXTERNAL_TEACHER_HEALTH="http://172.31.31.105:30000/health_generate"

# 8 GPU all for student: 4 actor (TP=4) + 4 rollout
ACTOR_GPUS=4
ACTOR_TP=4
ROLLOUT_GPUS=4

# Lightning-OPD paper recipe
LR=2e-6
NUM_ROLLOUT=600
ROLLOUT_BATCH_SIZE=64       # Lightning trains with bs=256, n=4 → 64 unique prompts/rollout
GLOBAL_BATCH_SIZE=256
N_SAMPLES=4
MAX_RESPONSE_LEN=4096
OPD_KL_COEF=1.0
SAVE_INTERVAL=50            # 600 rollouts → 12 ckpts
MAX_TOKENS_PER_GPU=16384    # response = 4K, prompt + few extra → fits comfortably
TEMPERATURE=0.8
TOP_P=1.0
TOP_K=-1                    # disable top-k

# Per-token KL dump (lighter — paper recipe should make OPD work, less analysis needed)
OPD_DUMP_KL_PATH="/root/.cache/huggingface/opd-4b-lightning-recipe/kl_dump/r{rollout_id}_rank{rank}.jsonl"
OPD_DUMP_KL_INTERVAL=20     # dump every 20 rollouts → 30 dumps total
OPD_DUMP_KL_MAX_SAMPLES=8
