# OPD Cumulative v2: SFT 100K checkpoint + Qwen3-8B teacher + cumulative KL (normalized)
# Changes from v1: K=2, kl_coef=1.0, max_response_len=16384, lr=1e-6, temp=1.0
MODEL_CONFIG=qwen3-8B
STUDENT_HF=/root/.cache/huggingface/sft-100k-merged
STUDENT_TORCH_DIST=/root/.cache/huggingface/sft-100k-torch_dist
TEACHER_HF=/root/.cache/huggingface/Qwen3-8B
TRAIN_DATA=/workspace/data/dapo-math-17k.jsonl
SAVE_DIR=/root/.cache/huggingface/opd-cumulative-v2-ckpt

TEACHER_TP=1
TEACHER_GPUS="7"
ACTOR_GPUS=2
ACTOR_TP=2
ROLLOUT_GPUS=5

LR=1e-6
NUM_ROLLOUT=300
ROLLOUT_BATCH_SIZE=16
GLOBAL_BATCH_SIZE=64
N_SAMPLES=4
MAX_RESPONSE_LEN=16384
OPD_KL_COEF=1.0
SAVE_INTERVAL=20
MAX_TOKENS_PER_GPU=16384
TEMPERATURE=1.0
TOP_P=0.95
TOP_K=20

# Cumulative OPD settings
OPD_CUMULATIVE=1
OPD_GAMMA=0.99
OPD_HORIZON=2
