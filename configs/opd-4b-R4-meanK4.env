# Phase 2.5 R4: mean-K=4 cumulative OPD (no code change, runs on current loss.py)
# Student: 4B Full FT v2 ckpt-700 (60% AIME, best 4B SFT baseline)
# Teacher: Qwen3-8B EXTERNAL on qzf-dev (172.31.31.105:30000, DP=4) — 8 GPU all for student
# Aggregation: mean (slime v2 default, divide by actual_k), K=4, gamma=1.0
# Reuses opd-4b-B paper recipe (lr=2e-6, T=0.8, max_resp=4096); 300 rollouts (iter_299 saturates)
MODEL_CONFIG=qwen3-4B
STUDENT_HF=/root/.cache/huggingface/sft-qwen3-4b-full-v2-ckpt700
STUDENT_TORCH_DIST=/root/.cache/huggingface/sft-qwen3-4b-full-v2-ckpt700-torch_dist
TEACHER_HF=/root/.cache/huggingface/Qwen3-8B
TRAIN_DATA=/workspace/data/dapo-math-17k/dapo-math-17k.jsonl
SAVE_DIR=/root/.cache/huggingface/opd-4b-R4-meanK4

# External teacher (qzf-dev) — frees all 8 GPUs for student (4 actor TP=4 + 4 rollout)
EXTERNAL_TEACHER_URL="http://172.31.31.105:30000/generate"
EXTERNAL_TEACHER_HEALTH="http://172.31.31.105:30000/health_generate"
ACTOR_GPUS=4
ACTOR_TP=4
ROLLOUT_GPUS=4

# opd-4b-B paper recipe
LR=2e-6
NUM_ROLLOUT=300
ROLLOUT_BATCH_SIZE=64
GLOBAL_BATCH_SIZE=256
N_SAMPLES=4
MAX_RESPONSE_LEN=4096
OPD_KL_COEF=1.0
SAVE_INTERVAL=50
MAX_TOKENS_PER_GPU=8192
TEMPERATURE=0.8
TOP_P=1.0
TOP_K=-1

# Cumulative OPD: mean-K=4 (gamma=1.0, truncated horizon -> divide by actual_k)
OPD_CUMULATIVE=1
OPD_GAMMA=1.0
OPD_HORIZON=4

# KL dump (every 10 rollouts) for offline analysis
OPD_DUMP_KL_PATH=/root/.cache/huggingface/opd-4b-R4-meanK4/kl_dump/r{rollout_id}_rank{rank}.jsonl
OPD_DUMP_KL_INTERVAL=10
OPD_DUMP_KL_MAX_SAMPLES=8
