# Instant OPD on top of 4B Full FT v2 ckpt-700 (60% AIME, our best 4B SFT)
# Dumps full per-token KL data (with token ids) every rollout for offline analysis.
#
# Student: 4B Full FT v2 ckpt-700  (Qwen3-4B-Base, AIME-2024 60%)
# Teacher: Qwen3-8B post-trained    (AIME-2024 73.3%)
# Gap: ~13pt — small-but-positive headroom for OPD.

MODEL_CONFIG=qwen3-4B
STUDENT_HF=/root/.cache/huggingface/sft-qwen3-4b-full-v2-ckpt700
STUDENT_TORCH_DIST=/root/.cache/huggingface/sft-qwen3-4b-full-v2-ckpt700-torch_dist
TEACHER_HF=/root/.cache/huggingface/Qwen3-8B
TRAIN_DATA=/workspace/data/dapo-math-17k.jsonl
SAVE_DIR=/root/.cache/huggingface/opd-4b-v2-ckpt700-instant

# 4B is much smaller than 8B → can use TP=2 actor + 4 rollout engines + TP=1 teacher
TEACHER_TP=1
TEACHER_GPUS="7"
ACTOR_GPUS=2
ACTOR_TP=2
ROLLOUT_GPUS=5

# Instant OPD recipe (matches the 8B run that hit +10pt AIME)
LR=5e-7
NUM_ROLLOUT=300
ROLLOUT_BATCH_SIZE=16
GLOBAL_BATCH_SIZE=64
N_SAMPLES=4
MAX_RESPONSE_LEN=8192
OPD_KL_COEF=1.0
SAVE_INTERVAL=25
MAX_TOKENS_PER_GPU=8192
TEMPERATURE=0.6
TOP_P=0.95
TOP_K=20

# Per-token KL dump (offline analysis)
OPD_DUMP_KL_PATH="/root/.cache/huggingface/opd-4b-v2-ckpt700-instant/kl_dump/r{rollout_id}_rank{rank}.jsonl"
OPD_DUMP_KL_INTERVAL=10        # dump every 10 rollouts (~30 dumps over 300 rollouts)
OPD_DUMP_KL_MAX_SAMPLES=8      # cap 8 samples per rank per dump → ~64/dump total
