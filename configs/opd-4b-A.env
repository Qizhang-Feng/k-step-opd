# ============================================================================
# opd-4b-A — conservative recipe (5/24 run)
# ============================================================================
# Originally named "instant-extteacher" (now misleading: all our runs are
# online/standard OPD; "instant" only meant "single-step in advantage").
#
# This is the hand-picked conservative config that ran 5/24, 300 rollouts.
# Best result: AIME-2024 = 54.4% (n=16) at iter_299, +5.6pt vs SFT baseline.
# See NAMING.md for the full mapping. opd-4b-B has paper recipe.
# ============================================================================

# Instant OPD on top of 4B Full FT v2 ckpt-700 (60% AIME).
# External teacher: Qwen3-8B served on qzf-dev (4×L40S, TP=4, port 30000).
# Local p5-3 is freed up to run 4 actor + 4 rollout → faster step time.
#
# Student: 4B Full FT v2 ckpt-700  (Qwen3-4B-Base, AIME-2024 60%)
# Teacher: Qwen3-8B post-trained    (AIME-2024 73.3%)
# Gap: ~13pt — small-but-positive headroom for OPD.

MODEL_CONFIG=qwen3-4B
STUDENT_HF=/root/.cache/huggingface/sft-qwen3-4b-full-v2-ckpt700
STUDENT_TORCH_DIST=/root/.cache/huggingface/sft-qwen3-4b-full-v2-ckpt700-torch_dist
TEACHER_HF=/root/.cache/huggingface/Qwen3-8B
TRAIN_DATA=/workspace/data/dapo-math-17k/dapo-math-17k.jsonl
SAVE_DIR=/root/.cache/huggingface/opd-4b-v2-ckpt700-instant

# External teacher served on qzf-dev (same VPC, private IP)
EXTERNAL_TEACHER_URL="http://172.31.31.105:30000/generate"
EXTERNAL_TEACHER_HEALTH="http://172.31.31.105:30000/health_generate"

# 8 GPU all for student: 4 actor (TP=4) + 4 rollout
ACTOR_GPUS=4
ACTOR_TP=4
ROLLOUT_GPUS=4

# Instant OPD recipe (matches the 8B run that hit +10pt AIME)
LR=5e-7
NUM_ROLLOUT=300
ROLLOUT_BATCH_SIZE=16
GLOBAL_BATCH_SIZE=64
N_SAMPLES=4
MAX_RESPONSE_LEN=8192
OPD_KL_COEF=1.0
SAVE_INTERVAL=25
MAX_TOKENS_PER_GPU=8192
TEMPERATURE=0.6
TOP_P=0.95
TOP_K=20

# Per-token KL dump (offline analysis)
OPD_DUMP_KL_PATH="/root/.cache/huggingface/opd-4b-v2-ckpt700-instant/kl_dump/r{rollout_id}_rank{rank}.jsonl"
OPD_DUMP_KL_INTERVAL=10        # dump every 10 rollouts (~30 dumps over 300 rollouts)
OPD_DUMP_KL_MAX_SAMPLES=8      # cap 8 samples per rank per dump → ~32 samples/dump (4 actor ranks)
