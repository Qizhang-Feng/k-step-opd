# Phase 2: Qwen3-8B-Base SFT 100K → OPD with Qwen3-8B teacher
# Student: SFT 100K checkpoint (MATH-500 79.6%)
# Teacher: Qwen3-8B post-trained (MATH-500 91.8%)
# Gap: ~12pt on MATH-500, ~27pt on AIME-2024

MODEL_CONFIG=qwen3-8B
STUDENT_HF=/workspace/k-step-opd/checkpoints/sft-qwen3-8b-base-lora-merged
STUDENT_TORCH_DIST=/workspace/k-step-opd/checkpoints/sft-qwen3-8b-base-lora-merged_torch_dist
TEACHER_HF=/root/.cache/huggingface/Qwen3-8B
TRAIN_DATA=/workspace/data/dapo-math-17k/dapo-math-17k.jsonl
SAVE_DIR=/workspace/k-step-opd/checkpoints/phase2-sft100k-opd

# 8B model needs more GPU resources
# Actor TP=4 (model + ref + optimizer need ~40GB/card with TP=4)
# Rollout 2 engines on remaining GPUs
# Teacher TP=2
TEACHER_TP=2
TEACHER_GPUS="6,7"
ACTOR_GPUS=4
ACTOR_TP=4
ROLLOUT_GPUS=2

# Training params
LR=5e-7
NUM_ROLLOUT=200
GLOBAL_BATCH_SIZE=32
N_SAMPLES=4
MAX_RESPONSE_LEN=8192
OPD_KL_COEF=1.0
SAVE_INTERVAL=25
MAX_TOKENS_PER_GPU=4096
