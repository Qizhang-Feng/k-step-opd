# Phase 2.5 R5: mean-K=8 + SOFT IS-weighted mask c=10 (improved algorithm)
# Motivation: R3b (hard mask) killed learning signal by completely removing high-IS tokens.
#   R1 (no mask) is best but has no variance control. This soft variant preserves signal
#   from high-IS tokens (weight = c/IS, never zero) while still downweighting their
#   contribution to the future cumulative sum.
# Student: 4B Full FT v2 ckpt-700 (best 4B SFT baseline)
# Teacher: Qwen3-8B EXTERNAL on qzf-dev (172.31.31.105:30000, DP=4)
# Aggregation: mean (divide by actual_k), K=8, gamma=1.0, kl_coef=1.0
# Soft mask: c=10, weight = min(c/IS, 1) for each token in future window.
#   IS ≤ 10 → weight=1 (full contribution); IS=20 → weight=0.5; IS=100 → weight=0.1
# Reuses opd-4b-B paper recipe; 300 rollouts; fast knobs.
MODEL_CONFIG=qwen3-4B
STUDENT_HF=/root/.cache/huggingface/sft-qwen3-4b-full-v2-ckpt700
STUDENT_TORCH_DIST=/root/.cache/huggingface/sft-qwen3-4b-full-v2-ckpt700-torch_dist
TEACHER_HF=/root/.cache/huggingface/Qwen3-8B
TRAIN_DATA=/workspace/data/dapo-math-17k/dapo-math-17k.jsonl
SAVE_DIR=/root/.cache/huggingface/opd-4b-R5-meanK8-softmask

EXTERNAL_TEACHER_URL="http://172.31.31.105:30000/generate"
EXTERNAL_TEACHER_HEALTH="http://172.31.31.105:30000/health_generate"
ACTOR_GPUS=4
ACTOR_TP=4
ROLLOUT_GPUS=4

# opd-4b-B paper recipe
LR=2e-6
NUM_ROLLOUT=300
ROLLOUT_BATCH_SIZE=64
GLOBAL_BATCH_SIZE=256
N_SAMPLES=4
MAX_RESPONSE_LEN=4096
OPD_KL_COEF=1.0
SAVE_INTERVAL=50
TEMPERATURE=0.8
TOP_P=1.0
TOP_K=-1

# FAST throughput knobs
MAX_TOKENS_PER_GPU=16384
LOG_PROBS_MAX_TOKENS_PER_GPU=24576
RECOMPUTE=0

# Cumulative OPD: mean-K=8 + soft IS-weighted mask c=10
OPD_CUMULATIVE=1
OPD_GAMMA=1.0
OPD_HORIZON=8
OPD_AGG=mean
OPD_DUALCLIP_C=10.0
OPD_SOFT_MASK=1

# KL dump (every 10 rollouts) for offline analysis
OPD_DUMP_KL_PATH=/root/.cache/huggingface/opd-4b-R5-meanK8-softmask/kl_dump/r{rollout_id}_rank{rank}.jsonl
OPD_DUMP_KL_INTERVAL=10
OPD_DUMP_KL_MAX_SAMPLES=8
